{
  "name": "jobfit-assistant",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "version:check": "node scripts/check-version.mjs",
    "desktop:fix-subsystem": "node scripts/fix-windows-subsystem.mjs",
    "desktop:check": "npm run version:check && node scripts/check-desktop-release.mjs",
    "build": "npm run version:check && tsc && vite build",
    "test": "vitest run",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "npm run desktop:check && tauri build",
    "desktop:bundle": "npm run desktop:check && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.5.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.5.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.9"
  }
}
